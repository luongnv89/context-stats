{
  "name": "cc-context-stats",
  "version": "1.16.1",
  "description": "Monitor your Claude Code session context in real-time - track token usage and never run out of context",
  "bin": {
    "context-stats": "scripts/context-stats.sh"
  },
  "scripts": {
    "format": "prettier --write '*.json' '*.md'",
    "format:check": "prettier --check '*.json' '*.md'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "context",
    "tokens",
    "monitoring",
    "statusline",
    "terminal",
    "cli",
    "dashboard"
  ],
  "author": "luongnv89",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luongnv89/cc-context-stats.git"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "files": [
    "scripts/context-stats.sh"
  ]
}
